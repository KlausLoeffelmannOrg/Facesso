<?xml version="1.0" encoding="utf-8"?><Database Name="MISDB" Class="KannegiesserDataContext" xmlns="http://schemas.microsoft.com/linqtosql/dbml/2007">
  <Connection Mode="AppSettings" ConnectionString="Data Source=pdc;Initial Catalog=MISDB;User ID=KabusUser" SettingsObjectName="Facesso.Interfaces.My.MySettings" SettingsPropertyName="MISDBConnectionString" Provider="System.Data.SqlClient" />
  <Function Name="PROGHIST.GetMachines" Method="GetMachines">
    <ElementType Name="GetMachinesResult">
      <Column Name="MachineID" Type="System.Int32" DbType="Int NOT NULL" CanBeNull="false" />
      <Column Name="MachineName" Type="System.String" DbType="NVarChar(10) NOT NULL" CanBeNull="false" />
    </ElementType>
  </Function>
  <Function Name="PROGHIST.GetProgHist" Method="GetProgHist">
    <Parameter Name="MachineID" Parameter="machineID" Type="System.Int32" DbType="Int" />
    <Parameter Name="ID" Parameter="iD" Type="System.Int32" DbType="Int" />
    <ElementType Name="GetProgHistResult">
      <Column Name="ID" Type="System.Int64" DbType="BigInt NOT NULL" CanBeNull="false" />
      <Column Name="DATUM" Type="System.DateTime" DbType="DateTime" CanBeNull="true" />
      <Column Name="TYP" Type="System.Int32" DbType="Int" CanBeNull="true" />
      <Column Name="ARTNR" Type="System.Int32" DbType="Int" CanBeNull="true" />
      <Column Name="STARTZEIT" Type="System.DateTime" DbType="DateTime" CanBeNull="true" />
      <Column Name="DAUER" Type="System.Double" DbType="Float" CanBeNull="true" />
      <Column Name="ZAEHLER" Type="System.Double" DbType="Float" CanBeNull="true" />
    </ElementType>
  </Function>
  <Function Name="PROGHIST.GetPrograms" Method="GetPrograms">
    <ElementType Name="GetProgramsResult">
      <Column Name="MachineID" Type="System.Int32" DbType="Int NOT NULL" CanBeNull="false" />
      <Column Name="ProgramID" Type="System.Int16" DbType="SmallInt NOT NULL" CanBeNull="false" />
      <Column Name="ProgramName" Type="System.String" DbType="NVarChar(27) NOT NULL" CanBeNull="false" />
    </ElementType>
  </Function>
  <Function Name="PROGHIST.GetArticles" Method="GetArticles">
    <ElementType Name="GetArticlesResult">
      <Column Name="ArticleID" Type="System.Int32" DbType="Int NOT NULL" CanBeNull="false" />
      <Column Name="ArticleName" Type="System.String" DbType="NVarChar(50) NOT NULL" CanBeNull="false" />
    </ElementType>
  </Function>
  <Function Name="PROGHIST.GetArtHist" Method="GetArtHist">
    <Parameter Name="MachineID" Parameter="machineID" Type="System.Int32" DbType="Int" />
    <Parameter Name="StartTime" Parameter="startTime" Type="System.DateTime" DbType="DateTime" />
    <Parameter Name="EndTime" Parameter="endTime" Type="System.DateTime" DbType="DateTime" />
    <ElementType Name="GetArtHistResult">
      <Column Name="StartTime" Type="System.DateTime" DbType="DateTime" CanBeNull="true" />
      <Column Name="EndTime" Type="System.DateTime" DbType="DateTime" CanBeNull="true" />
      <Column Name="SysID" Type="System.Int32" DbType="Int NOT NULL" CanBeNull="false" />
      <Column Name="SysShortName" Type="System.String" DbType="NVarChar(10)" CanBeNull="true" />
      <Column Name="SystemMaster" Type="System.Boolean" DbType="Bit NOT NULL" CanBeNull="false" />
      <Column Name="MachID" Type="System.Int32" DbType="Int NOT NULL" CanBeNull="false" />
      <Column Name="MachShortName" Type="System.String" DbType="NVarChar(10) NOT NULL" CanBeNull="false" />
      <Column Name="ProdDur" Type="System.Double" DbType="Float" CanBeNull="true" />
      <Column Name="ArticleName" Type="System.String" DbType="NVarChar(50) NOT NULL" CanBeNull="false" />
      <Column Name="ArticleID" Type="System.Int32" DbType="Int NOT NULL" CanBeNull="false" />
      <Column Name="Counter" Type="System.Double" DbType="Float" CanBeNull="true" />
      <Column Name="TargetDur1" Type="System.Double" DbType="Float" CanBeNull="true" />
      <Column Name="UnitName" Type="System.String" DbType="NVarChar(10)" CanBeNull="true" />
    </ElementType>
  </Function>
</Database>